# macOS metadata
.DS_Store

# Node dependencies
node_modules/

# Project-local runtime state for deep-memory + sibling deep-suite plugins
.deep-memory/
.deep-review/
.deep-work/
.deep-evolve/
.deep-docs/
.deep-wiki/
