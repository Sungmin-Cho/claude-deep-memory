{
  "description": "Deep Memory capture hooks supported by Codex.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/hooks/session-start.mjs\"",
            "commandWindows": "node \"%PLUGIN_ROOT%\\scripts\\hooks\\session-start.mjs\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/hooks/user-prompt-submit.mjs\"",
            "commandWindows": "node \"%PLUGIN_ROOT%\\scripts\\hooks\\user-prompt-submit.mjs\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/hooks/post-tool-use.mjs\"",
            "commandWindows": "node \"%PLUGIN_ROOT%\\scripts\\hooks\\post-tool-use.mjs\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/hooks/pre-compact.mjs\"",
            "commandWindows": "node \"%PLUGIN_ROOT%\\scripts\\hooks\\pre-compact.mjs\""
          }
        ]
      }
    ]
  }
}
